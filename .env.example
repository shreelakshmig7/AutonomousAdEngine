# ── Shreelakshmi Ad Engine — Environment Variables ──────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is listed in .gitignore.
#
# Drafter (Generate): Gemini 2.0 Flash — https://aistudio.google.com
# Judge (Evaluate):   Claude Sonnet 4.5 — https://console.anthropic.com

GOOGLE_API_KEY=your_google_ai_studio_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Image generation (Nano Banana) — google-genai SDK only in images/image_generator.py
# Image gen (Nano Banana). Preview id may 404; use ListModels — gemini-2.5-flash-image
IMAGE_GEN_MODEL=gemini-2.5-flash-image

# Optional: override models (defaults in generate/prompts.py)
# Drafter primary: gemini-2.5-flash. Fallback on Gemini rate limit: Claude Haiku (2.0-flash free tier = 0).
# FALLBACK_DRAFTER_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=claude-sonnet-4-5

# Parallel execution — tune to your API rate limits (see rate_limiter.py)
# PIPELINE_MAX_WORKERS=5        # Max concurrent brief×variation threads
# GEMINI_MAX_CONCURRENT=5       # Max concurrent Gemini API calls
# ANTHROPIC_MAX_CONCURRENT=2    # Max concurrent Anthropic/Claude API calls
# ANTHROPIC_CALL_DELAY=2.0      # Seconds between Anthropic calls (TPM throttle)
# IMAGE_MAX_WORKERS=4           # Max concurrent image generation calls (reduced to avoid rate limits)
# IMAGE_STAGGER_DELAY=0.5       # Seconds between image generation submissions
